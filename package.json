{
  "name": "baseball-manager",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --host",
    "tunnel": "lt --port 5173",
    "build": "vite build",
    "preview": "vite preview",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src",
    "test:integration": "vitest run src/engine scripts",
    "test:physics-hr": "vitest run scripts/validate-physics-hr.test.js",

    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",

    "test:all": "npm run test && npm run test:e2e",

    "validate:physics-hr": "vitest run scripts/validate-physics-hr.test.js"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "lz-string": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.7",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@vitejs/plugin-react": "^4.2.1",
    "localtunnel": "^2.0.2",
    "vite": "^5.4.0",
    "vitest": "^4.1.1"
  }
}
